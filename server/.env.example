# Copy this file to server/.env and fill in your values.

# TMDb v3 API key. Used to fetch movie posters for free and cache results locally.
TMDB_API_KEY=

# Optional free OpenSubtitles API key. Used to auto-fetch English captions when local/embedded subtitles are unavailable.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=LAS v1

# Optional: set true if you have NVIDIA NVENC working and want ffmpeg to use it.
HW_ACCEL=false
