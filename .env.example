# Docker Compose reads this file after you copy it to .env in the project root.

# External port for the web app.
LAS_PORT=8096

# Host folder containing your movies. Inside LAS settings, add /media.
# Windows example:
LAS_MEDIA_PATH=D:\Movies
# Linux/macOS example:
# LAS_MEDIA_PATH=/mnt/movies

# Free TMDb v3 API key for poster fetching.
TMDB_API_KEY=

# Optional free OpenSubtitles API key for automatic English captions.
# Docker Compose passes this into the container automatically via env_file.
# Create a free account/app at opensubtitles.com, then paste the API key here.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=LAS v1

# Set true only if Docker has NVIDIA GPU access and ffmpeg NVENC works.
HW_ACCEL=false
